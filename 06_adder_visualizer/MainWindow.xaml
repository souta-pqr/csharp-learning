<Window x:Class="_06_adder_visualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="2進数加算ビジュアライザ" Height="720" Width="1050"
        Background="#1E1E2E" FontFamily="Consolas">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 入力 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
            <TextBlock Text="A = " Foreground="#CDD6F4" FontSize="22" VerticalAlignment="Center"/>
            <TextBox x:Name="InputA" Text="2" Width="70" FontSize="22" TextAlignment="Center"
                     Background="#313244" Foreground="#89DCEB" BorderBrush="#89B4FA"
                     CaretBrush="White" Padding="4"/>
            <TextBlock Text="  +  B = " Foreground="#CDD6F4" FontSize="22" VerticalAlignment="Center"/>
            <TextBox x:Name="InputB" Text="15" Width="70" FontSize="22" TextAlignment="Center"
                     Background="#313244" Foreground="#A6E3A1" BorderBrush="#89B4FA"
                     CaretBrush="White" Padding="4"/>
            <Button x:Name="BtnStart" Content="▶ スタート" Margin="20,0,0,0"
                    Padding="16,6" FontSize="18" Background="#89B4FA" Foreground="#1E1E2E"
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnStart_Click"/>
            <Button Content="↺ リセット" Margin="10,0,0,0"
                    Padding="16,6" FontSize="18" Background="#585B70" Foreground="#CDD6F4"
                    BorderThickness="0" Cursor="Hand" Click="BtnReset_Click"/>
        </StackPanel>

        <!-- 2進数ビット表示 -->
        <Border Grid.Row="1" Background="#313244" CornerRadius="8" Padding="16,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="A" Foreground="#89DCEB" FontSize="18" VerticalAlignment="Center"/>
                <ItemsControl x:Name="BitsA" Grid.Row="0" Grid.Column="1">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="B" Foreground="#A6E3A1" FontSize="18" VerticalAlignment="Center"/>
                <ItemsControl x:Name="BitsB" Grid.Row="1" Grid.Column="1">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Carry" Foreground="#FAB387" FontSize="14" VerticalAlignment="Center"/>
                <ItemsControl x:Name="BitsCarry" Grid.Row="2" Grid.Column="1">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Sum" Foreground="#F38BA8" FontSize="18" VerticalAlignment="Center"/>
                <ItemsControl x:Name="BitsSum" Grid.Row="3" Grid.Column="1">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- ゲート描画 -->
        <Border Grid.Row="2" Background="#181825" CornerRadius="8" ClipToBounds="True">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="GateCanvas" Width="1010" Height="320"/>
            </ScrollViewer>
        </Border>

        <!-- ログ -->
        <Border Grid.Row="3" Background="#181825" CornerRadius="6" Padding="10,6" Margin="0,8,0,0">
            <TextBlock x:Name="LogText" Foreground="#CDD6F4" FontSize="14" TextWrapping="Wrap" MinHeight="20"/>
        </Border>
    </Grid>
</Window>
