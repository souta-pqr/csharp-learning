<Window x:Class="_06_adder_visualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ripple Carry Adder Visualizer" Height="780" Width="1100"
        Background="#0F0F1A" FontFamily="Consolas">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 入力 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
            <TextBlock Text="A = " Foreground="#CDD6F4" FontSize="22" VerticalAlignment="Center"/>
            <TextBox x:Name="InputA" Text="2" Width="70" FontSize="22" TextAlignment="Center"
                     Background="#1E1E2E" Foreground="#89DCEB" BorderBrush="#89B4FA"
                     CaretBrush="White" Padding="4"/>
            <TextBlock Text="  +  B = " Foreground="#CDD6F4" FontSize="22" VerticalAlignment="Center"/>
            <TextBox x:Name="InputB" Text="15" Width="70" FontSize="22" TextAlignment="Center"
                     Background="#1E1E2E" Foreground="#A6E3A1" BorderBrush="#89B4FA"
                     CaretBrush="White" Padding="4"/>
            <Button x:Name="BtnStep" Content="▶ Step" Margin="20,0,4,0"
                    Padding="14,6" FontSize="18" Background="#89B4FA" Foreground="#0F0F1A"
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnStep_Click"/>
            <Button x:Name="BtnAuto" Content="⏩ Auto" Margin="4,0,4,0"
                    Padding="14,6" FontSize="18" Background="#CBA6F7" Foreground="#0F0F1A"
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnAuto_Click"/>
            <Button Content="↺" Margin="4,0,0,0"
                    Padding="12,6" FontSize="18" Background="#45475A" Foreground="#CDD6F4"
                    BorderThickness="0" Cursor="Hand" Click="BtnReset_Click"/>
        </StackPanel>

        <!-- ビット表示バー -->
        <Border Grid.Row="1" Background="#1E1E2E" CornerRadius="8" Padding="12,8" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="A" Foreground="#89DCEB" FontSize="17" VerticalAlignment="Center"/>
                <ItemsControl x:Name="BitsA" Grid.Row="0" Grid.Column="1">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="B" Foreground="#A6E3A1" FontSize="17" VerticalAlignment="Center"/>
                <ItemsControl x:Name="BitsB" Grid.Row="1" Grid.Column="1">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Carry" Foreground="#FAB387" FontSize="13" VerticalAlignment="Center"/>
                <ItemsControl x:Name="BitsCarry" Grid.Row="2" Grid.Column="1">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Sum" Foreground="#F38BA8" FontSize="17" VerticalAlignment="Center"/>
                <ItemsControl x:Name="BitsSum" Grid.Row="3" Grid.Column="1">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
                <TextBlock x:Name="ResultLabel" Grid.Row="3" Grid.Column="2"
                           Foreground="#F38BA8" FontSize="17" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- 回路キャンバス -->
        <Border Grid.Row="2" Background="#13131F" CornerRadius="10" ClipToBounds="True">
            <Canvas x:Name="GateCanvas"/>
        </Border>

        <!-- ログ -->
        <Border Grid.Row="3" Background="#1E1E2E" CornerRadius="6" Padding="10,7" Margin="0,8,0,0">
            <TextBlock x:Name="LogText" Foreground="#CDD6F4" FontSize="14" TextWrapping="Wrap" MinHeight="22"/>
        </Border>
    </Grid>
</Window>
